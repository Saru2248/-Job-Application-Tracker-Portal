# ====================================
# Job Application Tracker Portal
# Environment Variables Template
# ====================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to GitHub!

# ----- SERVER -----
PORT=5000
NODE_ENV=development

# ----- MONGODB -----
# Get this from https://cloud.mongodb.com (MongoDB Atlas) or use local: mongodb://localhost:27017/jobtracker
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/jobtracker?retryWrites=true&w=majority

# ----- JWT -----
# Use a long random string — you can generate one at: https://randomkeygen.com/
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# ----- CLIENT -----
# Only needed if you change the default port
# REACT_APP_API_URL=http://localhost:5000/api
